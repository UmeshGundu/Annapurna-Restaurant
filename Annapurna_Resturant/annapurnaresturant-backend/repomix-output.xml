    private String tag;

    @Column(name = "tag_icon")
    private String tagIcon;

    private String name;

    private String line1;

    private String line2;

    private String city;

    private String state;

    private String pincode;

    private String phone;

    @Column(name = "is_default")
    @Builder.Default
    private Boolean isDefault = false;
}
